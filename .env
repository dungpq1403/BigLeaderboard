# =========================
# Credentials cho docker-compose.prod.yml
# =========================
# LƯU Ý: MySQL image KHÔNG cho phép MYSQL_USER=root.
# Phải đặt DB_USER khác 'root'. Đổi password trước khi deploy thật.
DB_ROOT_PASSWORD=rootroot
DB_USER=bigleader_user
DB_PASSWORD=ChangeMe_StrongPassword
DB_NAME=BigLeaderboard

JWT_SECRET=bigleaderboard_super_secret_key

# URL public mà BROWSER sẽ gọi backend tới (đổi thành domain thật khi deploy)
NEXT_PUBLIC_API_URL=http://localhost:5000/api
